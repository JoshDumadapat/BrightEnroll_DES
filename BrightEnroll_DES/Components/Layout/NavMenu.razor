﻿@using BrightEnroll_DES.Services.RoleBase
@using BrightEnroll_DES.Services.Authentication
@using Microsoft.AspNetCore.Components
@inject IAuthorizationService AuthorizationService
@inject IAuthService AuthService
@inject NavigationManager Navigation
@implements IDisposable

@code {
    [Parameter] public EventCallback OnNavigate { get; set; }
    [Parameter] public EventCallback OnLogout { get; set; }

    // Computed property that re-evaluates on every access
    private bool IsSuperAdminUser
    {
        get
        {
            var currentRole = AuthService.CurrentUser?.user_role ?? AuthorizationService.GetUserRole();
            if (string.IsNullOrWhiteSpace(currentRole))
            {
                System.Diagnostics.Debug.WriteLine($"[NavMenu] IsSuperAdminUser - No role found. IsAuthenticated: {AuthService.IsAuthenticated}, CurrentUser: {AuthService.CurrentUser != null}");
                return false;
            }
            
            // Handle both "Super Admin" (with space) and "SuperAdmin" (no space)
            var isSuperAdmin = currentRole.Equals("Super Admin", StringComparison.OrdinalIgnoreCase) ||
                               currentRole.Replace(" ", "").Equals("Super Admin", StringComparison.OrdinalIgnoreCase);
            
            System.Diagnostics.Debug.WriteLine($"[NavMenu] IsSuperAdminUser getter - Role: '{currentRole}', IsSuperAdmin: {isSuperAdmin}");
            return isSuperAdmin;
        }
    }

    protected override void OnInitialized()
    {
        // Subscribe to navigation changes to force re-render
        Navigation.LocationChanged += OnLocationChanged;
        
        // Force initial check
        System.Diagnostics.Debug.WriteLine($"[NavMenu] OnInitialized - IsAuthenticated: {AuthService.IsAuthenticated}, CurrentUser: {AuthService.CurrentUser?.system_ID}, Role: {AuthService.CurrentUser?.user_role}");
        Console.WriteLine($"[NavMenu] OnInitialized - IsAuthenticated: {AuthService.IsAuthenticated}, CurrentUser: {AuthService.CurrentUser?.system_ID}, Role: {AuthService.CurrentUser?.user_role}");
    }

    protected override void OnParametersSet()
    {
        // Re-check on parameter changes
        System.Diagnostics.Debug.WriteLine($"[NavMenu] OnParametersSet - IsAuthenticated: {AuthService.IsAuthenticated}, Role: {AuthService.CurrentUser?.user_role}, IsSuperAdmin: {IsSuperAdminUser}");
        Console.WriteLine($"[NavMenu] OnParametersSet - IsAuthenticated: {AuthService.IsAuthenticated}, Role: {AuthService.CurrentUser?.user_role}, IsSuperAdmin: {IsSuperAdminUser}");
        StateHasChanged(); // Force re-render
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Wait a bit for auth state to be ready, then force re-render
            await Task.Delay(100);
            System.Diagnostics.Debug.WriteLine($"[NavMenu] OnAfterRenderAsync - IsAuthenticated: {AuthService.IsAuthenticated}, Role: {AuthService.CurrentUser?.user_role}, IsSuperAdmin: {IsSuperAdminUser}");
            StateHasChanged();
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        // Force re-render on navigation
        System.Diagnostics.Debug.WriteLine($"[NavMenu] Location changed to: {e.Location}, IsSuperAdmin: {IsSuperAdminUser}");
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private async Task HandleNavigate()
    {
        await OnNavigate.InvokeAsync();
        // Force re-evaluation of IsSuperAdminUser after navigation
        StateHasChanged();
    }

    private async Task HandleLogout()
    {
        await OnLogout.InvokeAsync();
    }

    // Helper method to get the correct dashboard path based on role
    private string GetDashboardPath()
    {
        if (IsSuperAdminUser)
        {
            return "/system-admin/dashboard";
        }
        return "/dashboard";
    }

    // Check if user is SuperAdmin
    private bool IsSuperAdmin()
    {
        // Try AuthService first (most direct), then AuthorizationService as fallback
        var userRole = AuthService.CurrentUser?.user_role ?? AuthorizationService.GetUserRole();
        
        if (string.IsNullOrWhiteSpace(userRole))
        {
            System.Diagnostics.Debug.WriteLine($"[NavMenu] IsSuperAdmin - No role found. IsAuthenticated: {AuthService.IsAuthenticated}, CurrentUser: {AuthService.CurrentUser != null}");
            return false;
        }

        // Handle both "Super Admin" (with space) and "SuperAdmin" (no space)
        var isSuperAdmin = userRole.Equals("Super Admin", StringComparison.OrdinalIgnoreCase) ||
                          userRole.Replace(" ", "").Equals("SuperAdmin", StringComparison.OrdinalIgnoreCase);
        
        // Debug logging
        System.Diagnostics.Debug.WriteLine($"[NavMenu] IsSuperAdmin check - Role: '{userRole}', Result: {isSuperAdmin}");
        Console.WriteLine($"[NavMenu] IsSuperAdmin check - Role: '{userRole}', Result: {isSuperAdmin}");
        
        return isSuperAdmin;
    }

    // Check if user is Admin (but not SuperAdmin)
    private bool IsAdmin()
    {
        var userRole = AuthorizationService.GetUserRole();
        if (string.IsNullOrWhiteSpace(userRole))
        {
            return false;
        }

        // Normalize role: remove spaces and convert to lowercase
        var roleNormalized = userRole.Replace(" ", "").ToLower().Trim();
        return roleNormalized == "admin";
    }

    // Check if user is Admin or SuperAdmin - they see all menu items
    private bool IsAdminOrSuperAdmin()
    {
        return IsAdmin() || IsSuperAdmin();
    }

    // Helper to check if menu item should be shown
    private bool ShouldShowMenuItem(string permission)
    {
        // Admin, System Admin, and Super Admin see everything - no permission checks needed
        // EXCEPT for Teacher-only modules (Attendance and Gradebook)
        if (IsAdminOrSuperAdmin())
        {
            // Attendance and Gradebook are Teacher-only, even for Admins
            if (permission == Permissions.ViewAttendance || permission == Permissions.ViewGradebook)
            {
                return false;
            }
            return true;
        }
        // Other roles need permission
        return AuthorizationService.HasPermission(permission);
    }

    // Check if user is Teacher
    private bool IsTeacher()
    {
        var userRole = AuthorizationService.GetUserRole();
        if (string.IsNullOrWhiteSpace(userRole))
        {
            return false;
        }
        return string.Equals(userRole, "Teacher", StringComparison.OrdinalIgnoreCase);
    }
}

