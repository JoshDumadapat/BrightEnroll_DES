                       class="w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700 outline-none" readonly />
            </div>
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-700">Amount Paid</label>
                <input type="text" @bind="NewPaymentRecord.AmountPaid" 
