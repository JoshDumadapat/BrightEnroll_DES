                Confirm Payment
            </button>
            <button @onclick="PaymentConfirmationModal.Hide" class="rounded-lg bg-red-600 px-4 py-2 font-semibold text-white shadow-md transition-all duration-300 hover:bg-red-700">
                Cancel
            </button>
        </div>
    </div>
</Modal>

