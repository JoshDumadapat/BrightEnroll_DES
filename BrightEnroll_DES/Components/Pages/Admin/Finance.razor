<!-- View Expense Modal -->
<Modal @ref="ViewExpenseModal" Title="Expense Details">
    <div class="p-6">
        <h3 class="mb-4 text-lg font-semibold text-gray-800">Expense Information</h3>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-700">Expense ID</label>
                <input type="text" @bind="SelectedExpense.ExpenseId" 
                       class="w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700 outline-none" readonly />
            </div>
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-700">Date</label>
                <input type="text" value="@SelectedExpense.ExpenseDate.ToString("MMM dd, yyyy")"
                       class="w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700 outline-none" readonly />
            </div>
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-700">Category</label>
                <input type="text" @bind="SelectedExpense.Category" 
                       class="w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700 outline-none" readonly />
            </div>
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-700">Amount</label>
                <input type="text" @bind="SelectedExpense.Amount" 
                       class="w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700 outline-none" readonly />
            </div>
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-700">Payee</label>
                <input type="text" @bind="SelectedExpense.Payee" 
                       class="w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700 outline-none" readonly />
            </div>
            <div class="sm:col-span-2">
                <label class="mb-2 block text-sm font-medium text-gray-700">Description</label>
                <textarea @bind="SelectedExpense.Description" rows="3"
                          class="w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700 outline-none" readonly></textarea>
            </div>
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-700">Receipt Number</label>
                <input type="text" @bind="SelectedExpense.ReceiptNumber" 
                       class="w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700 outline-none" readonly />
            </div>
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-700">Payment Method</label>
                <input type="text" @bind="SelectedExpense.PaymentMethod" 
                       class="w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700 outline-none" readonly />
            </div>
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-700">Recorded By</label>
                <input type="text" @bind="SelectedExpense.RecordedBy" 
                       class="w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700 outline-none" readonly />
            </div>
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-700">Approved By</label>
                <input type="text" @bind="SelectedExpense.ApprovedBy" 
                       class="w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700 outline-none" readonly />
            </div>
            <div>
                <label class="mb-2 block text-sm font-medium text-gray-700">Status</label>
                <input type="text" @bind="SelectedExpense.Status" 
                       class="w-full rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700 outline-none" readonly />
            </div>
        </div>

        <!-- Attachments -->
        <div class="mt-4">
            <label class="mb-2 block text-sm font-medium text-gray-700">Attachments</label>
            <div class="flex flex-col gap-2">
                @if (SelectedExpense.Attachments != null && SelectedExpense.Attachments.Any())
                {
                    @foreach (var attachment in SelectedExpense.Attachments)
                    {
                        <div class="flex items-center justify-between rounded-lg border border-gray-300 bg-gray-100 px-3 py-2 text-sm text-gray-700">
                            <span class="line-clamp-1">@attachment.FileName</span>
                            <div class="flex gap-2">
                                <button @onclick="() => DownloadAttachment(attachment)"
                                        class="text-blue-600 hover:underline">
                                    Download
                                </button>
                                <button @onclick="() => DeleteAttachment(attachment)"
                                        class="text-red-600 hover:underline">
                                    Delete
                                </button>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <span class="text-gray-500 text-sm">No attachments found.</span>
                }
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="mt-6 flex justify-end gap-3">
            <button @onclick="CloseViewExpenseModal" class="rounded-lg bg-gray-300 px-4 py-2 font-semibold text-gray-700 transition-all duration-300 hover:bg-gray-400">
                Close
            </button>
        </div>
    </div>
</Modal>

<!-- Payment Confirmation Modal -->
<Modal @ref="PaymentConfirmationModal" Title="Confirm Payment">
    <div class="p-6">
        <h3 class="mb-4 text-lg font-semibold text-gray-800">Payment Confirmation</h3>
        <p class="mb-4 text-sm text-gray-700">
            Are you sure you want to proceed with the payment of <strong>Php @PaymentData.NewPaymentAmount</strong> for
            <strong>@PaymentData.StudentName</strong> (ID: @PaymentData.StudentId)?
