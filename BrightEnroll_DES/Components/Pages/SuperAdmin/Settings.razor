@page "/superadmin/settings"
@layout Components.Layout.MainLayout
@using BrightEnroll_DES.Services
@using BrightEnroll_DES.Services.Authentication
@inject IAuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Super Admin Settings</PageTitle>

<div class="text-gray-800">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">System Settings</h1>
            <p class="mt-1 text-sm text-gray-600">Manage system configuration and preferences</p>
        </div>
        <button @onclick="GoBack" class="flex items-center gap-2 rounded-full bg-gray-600 px-4 py-2 text-sm font-medium text-white shadow-md transition-all duration-300 hover:bg-gray-700 hover:shadow-lg">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Back
        </button>
    </div>
</div>

<!-- Settings Content -->
<div class="rounded-xl border border-gray-100 bg-white p-6 shadow-sm">
    <p class="text-gray-600">System settings and configuration options will be available here.</p>
</div>

@code {
    protected override void OnInitialized()
    {
        // Check if user is a super admin
        var userRole = AuthService.CurrentUser?.user_role;
        if (string.IsNullOrWhiteSpace(userRole) || !string.Equals(userRole, "SuperAdmin", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/dashboard");
            return;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/superadmin/dashboard");
    }
}

