@page "/superadmin/dashboard"
@layout Components.Layout.MainLayout
@using BrightEnroll_DES.Services
@using BrightEnroll_DES.Services.Authentication
@inject IAuthService AuthService
@inject ILoadingService LoadingService
@inject NavigationManager Navigation

<PageTitle>Super Admin Dashboard</PageTitle>

<div class="text-gray-800">
    <h1 class="mb-6 text-2xl font-bold text-gray-800">Super Admin Dashboard</h1>
    <p class="mb-6 text-sm text-gray-600">Welcome, @GetAdminName()!</p>
</div>

<!-- Quick Stats -->
<div class="mb-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
        <div class="mb-4 flex items-start justify-between">
            <div>
                <p class="mb-1 text-sm font-medium text-gray-500">Total Users</p>
                <h3 class="text-3xl font-bold text-gray-800">-</h3>
            </div>
            <div class="rounded-xl bg-blue-100 p-3">
                <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
            </div>
        </div>
    </div>

    <div class="rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
        <div class="mb-4 flex items-start justify-between">
            <div>
                <p class="mb-1 text-sm font-medium text-gray-500">System Status</p>
                <h3 class="text-3xl font-bold text-gray-800">Active</h3>
            </div>
            <div class="rounded-xl bg-green-100 p-3">
                <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="mb-6">
    <h2 class="mb-4 text-xl font-bold text-gray-800">Quick Actions</h2>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <button @onclick="NavigateToSettings" class="flex items-center gap-4 rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition-all hover:shadow-md">
            <div class="rounded-lg bg-blue-100 p-3">
                <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
            </div>
            <div class="text-left">
                <h3 class="font-semibold text-gray-800">System Settings</h3>
                <p class="text-sm text-gray-500">Manage system configuration</p>
            </div>
        </button>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Hide loading screen if it's still showing from login
        LoadingService.HideLoading();
        
        // Check if user is a super admin
        var userRole = AuthService.CurrentUser?.user_role;
        if (string.IsNullOrWhiteSpace(userRole) || !string.Equals(userRole, "SuperAdmin", StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo("/dashboard");
            return;
        }
    }

    private string GetAdminName()
    {
        var user = AuthService.CurrentUser;
        if (user == null) return "Super Admin";
        
        return $"{user.first_name} {user.last_name}";
    }

    private void NavigateToSettings()
    {
        Navigation.NavigateTo("/settings");
    }
}

